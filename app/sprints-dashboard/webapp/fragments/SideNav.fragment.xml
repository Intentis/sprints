<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">
    <tnt:SideNavigation selectedKey="home" itemSelect="onItemSelect" width="4rem">
        <tnt:item>
            <tnt:NavigationList>
                <tnt:NavigationListItem icon="sap-icon://home" key="home" class="largeIcon" tooltip="Home" />
                <tnt:NavigationListItem icon="sap-icon://target-group" key="leaderboard" class="largeIcon" tooltip="Leaderboard" />
                <tnt:NavigationListItem icon="sap-icon://learning-assistant" key="mySprints" class="largeIcon" tooltip="My Sprints" />
            </tnt:NavigationList>
        </tnt:item>
        <tnt:fixedItem>
            <tnt:NavigationList>
                <tnt:NavigationListItem icon="sap-icon://course-book" key="cap-resources" class="largeIcon" tooltip="Official CAP Documentation" press="onCAPDocumentationPress" />
                <tnt:NavigationListItem icon="sap-icon://sap-ui5" key="ui5-resources" class="largeIcon" tooltip="Official UI5 Documentation" press="onUI5DocumentationPress" />
                <tnt:NavigationListItem icon="sap-icon://sys-help" key="help" class="largeIcon" tooltip="Help" />
            </tnt:NavigationList>
        </tnt:fixedItem>
    </tnt:SideNavigation>
</core:FragmentDefinition>
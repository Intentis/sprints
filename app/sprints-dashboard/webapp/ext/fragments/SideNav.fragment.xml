<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">
    <tnt:SideNavigation selectedKey="home" width="4rem">
        <tnt:item>
            <tnt:NavigationList expanded="false" itemSelect="onItemSelect">
                <tnt:NavigationListItem icon="sap-icon://home" key="home" class="largeIcon" text="Home" />
                <tnt:NavigationListItem icon="sap-icon://target-group" key="leaderboard" class="largeIcon" text="Leaderboard" />
                <tnt:NavigationListItem icon="sap-icon://learning-assistant" key="mySprints" class="largeIcon" text="My Sprints" />
            </tnt:NavigationList>
        </tnt:item>
        <tnt:fixedItem>
            <tnt:NavigationList expanded="false">
                <tnt:NavigationListItem icon="sap-icon://course-book" key="cap-resources" class="largeIcon" text="Official CAP Documentation" press="onCAPDocumentationPress" />
                <tnt:NavigationListItem icon="sap-icon://sap-ui5" key="ui5-resources" class="largeIcon" text="Official UI5 Documentation" press="onUI5DocumentationPress" />
                <tnt:NavigationListItem icon="sap-icon://sys-help" key="issue" class="largeIcon" text="Raise an Issue" press="onRaiseIssuePress" />
            </tnt:NavigationList>
        </tnt:fixedItem>
    </tnt:SideNavigation>
</core:FragmentDefinition>
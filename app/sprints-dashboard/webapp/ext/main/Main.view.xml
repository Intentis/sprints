<mvc:View 
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:macros="sap.fe.macros" 
    xmlns:html="http://www.w3.org/1999/xhtml" 
    controllerName="sprints.portal.sprintsdashboard.ext.main.Main"
    displayBlock="true"
>
<tnt:ToolPage id="toolPage">
    <tnt:header>
        <core:Fragment fragmentName="sprints.portal.sprintsdashboard.ext.fragments.Header" type="XML" />
    </tnt:header>
    <tnt:sideContent>
        <core:Fragment fragmentName="sprints.portal.sprintsdashboard.ext.fragments.SideNav" type="XML" />
    </tnt:sideContent>
    <tnt:mainContents>
        <App id="mainContent" />
        <VBox width="100%" class="sprintsFooterContainer">
            <OverflowToolbar class="sprintsFooterBar">
                <Text text="© 2026 Sprints by Intentis" class="sapUiSmallMarginBegin sprintsFooterText" />
                <ToolbarSpacer />
                <Text text="Built with ❤️ by Deepak Jain" class="sprintsFooterText" />
                <ToolbarSeparator class="sapUiSmallMarginBeginEnd" />
                <HBox alignItems="Center">
                    <Link text="GitHub" href="https://github.com/Deepak14Jain" target="_blank" class="sapUiTinyMarginEnd" />            
                    <Link text="LinkedIn" href="https://www.linkedin.com/in/deepak14jain/" target="_blank" class="sapUiSmallMarginBegin sapUiTinyMarginEnd" />
                </HBox>
                <ToolbarSpacer width="1rem" />
            </OverflowToolbar>
        </VBox>
    </tnt:mainContents>
</tnt:ToolPage>
</mvc:View>
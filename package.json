{
  "name": "sprints",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^9",
    "cors": "^2.8.6",
    "express": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.13.0",
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-intentis-dashboard": "cds watch --open intentis-dashboard/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-sprints-dashboard": "cds watch --open sprints-dashboard/webapp/index.html?sap-ui-xx-viewCache=false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/sprints.db"
        }
      }
    }
  },
  "sapux": [
    "app/intentis-dashboard",
    "app/sprints-dashboard"
  ]
}

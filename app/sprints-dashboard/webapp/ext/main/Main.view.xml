<mvc:View 
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:macros="sap.fe.macros" 
    xmlns:html="http://www.w3.org/1999/xhtml" 
    controllerName="sprints.portal.sprintsdashboard.ext.main.Main"
    displayBlock="true"
>

<tnt:ToolPage id="toolPage">
    <tnt:header>
        <core:Fragment fragmentName="sprints.portal.sprintsdashboard.fragments.Header" type="XML" />
    </tnt:header>

    <tnt:sideContent>
        <core:Fragment fragmentName="sprints.portal.sprintsdashboard.fragments.SideNav" type="XML" />
    </tnt:sideContent>

    <tnt:mainContents>
        <ScrollContainer vertical="true" horizontal="false" height="100%" width="100%">
            <VBox class="homepage-bg-gradient sprintsHeroHeight">
            <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="sapUiMediumPadding">
                
                <VBox class="sapUiLargeMarginBegin">
                    <Title text="Welcome Back, Deepak!" level="H1" class="sprintsGreetingText sapUiLargeMarginTop sapUiLargeMarginBottom" />
                </VBox>
                <HBox alignContent="End" class="sapUiMediumMarginEnd">
                    <core:Fragment fragmentName="sprints.portal.sprintsdashboard.fragments.QuickStatus" type="XML" />
                </HBox>
            </HBox>
        </VBox>
            <VBox width="100%" class="sprintsContentOverlap sprintsContentPadding">
                <core:Fragment fragmentName="sprints.portal.sprintsdashboard.fragments.ResumeQuest" type="XML" />
            </VBox>
            <VBox width="100%" >
                
                <core:Fragment fragmentName="sprints.portal.sprintsdashboard.fragments.TrackSelection" type="XML" />
            </VBox>

        <VBox width="100%" class="sprintsFooterContainer">
    <OverflowToolbar class="sprintsFooterBar">
        <Text text="© 2026 Sprints by Intentis" class="sapUiSmallMarginBegin sprintsFooterText" />
        
        <ToolbarSpacer />

        <Text text="Built with ❤️ by Deepak Jain" class="sprintsFooterText" />
        <ToolbarSeparator class="sapUiSmallMarginBeginEnd" />
        
        <HBox alignItems="Center">
            <Link text="GitHub" href="https://github.com/Deepak14Jain" target="_blank" class="sapUiTinyMarginEnd" />            
            <Link text="LinkedIn" href="https://www.linkedin.com/in/deepak14jain/" target="_blank" class="sapUiSmallMarginBegin sapUiTinyMarginEnd" />
        </HBox>
        
        <ToolbarSpacer width="1rem" />
    </OverflowToolbar>
</VBox>
        </ScrollContainer>
    </tnt:mainContents>
</tnt:ToolPage>


</mvc:View>
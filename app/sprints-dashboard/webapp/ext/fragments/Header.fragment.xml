<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">
    <tnt:ToolHeader>
        <Image src="resources/images/logo.png" height="2.5rem" class="sapUiSmallMarginBegin" />
        <ToolbarSpacer />
        <Button icon="sap-icon://bell" type="Transparent" tooltip="Notifications" press="onNotificationPress" />
        <Button icon="sap-icon://settings" type="Transparent" tooltip="Settings" press="onSettingsPress" />
        <Avatar src="sap-icon://customer" displaySize="XS" badgeTooltip="My Profile" press="onProfilePress" />
    </tnt:ToolHeader>
</core:FragmentDefinition>